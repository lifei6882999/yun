# ============================================================
# OpenWrt 云源编译配置 - MediaTek Filogic (MT7981/MT7986/MT7988)
# 适用版本: OpenWrt 24.10.x
# ============================================================

# ===== 目标平台 =====
CONFIG_TARGET_mediatek=y
CONFIG_TARGET_mediatek_filogic=y
CONFIG_TARGET_MULTI_PROFILE=y

# ===== 全量编译 =====
# 编译所有内核模块 (kmod-*)
CONFIG_ALL_KMODS=y
# 编译所有用户态软件包
CONFIG_ALL_NONSHARED=y

# ===== 开发者选项 =====
CONFIG_DEVEL=y
CONFIG_CCACHE=y
CONFIG_BUILD_LOG=y

# ===== SDK 和 ImageBuilder =====
CONFIG_SDK=y
CONFIG_IB=y
CONFIG_MAKE_TOOLCHAIN=y

# ===== 不自动删除依赖 =====
CONFIG_AUTOREMOVE=n

# ===== 安全加固 =====
CONFIG_PKG_CHECK_FORMAT_SECURITY=y
CONFIG_KERNEL_CC_STACKPROTECTOR_STRONG=y

# ===== 禁用包签名 (使用自定义云源) =====
# CONFIG_SIGNED_PACKAGES is not set
